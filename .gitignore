# ==============================================================================
# eParadise UI - Múltiplos Ambientes (Odoo + ROS + IoT Hardware)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Python & Compilação Base
# ------------------------------------------------------------------------------
__pycache__/
*.py[codz]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
lib/
lib64/
*.egg-info/
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# 2. Odoo ERP (Módulos e Configurações Locais)
# ------------------------------------------------------------------------------
# Logs gerados pelo servidor Odoo
*.log
odoo.log
odoo-server.log

# Arquivos de configuração local do Odoo (não envie senhas do banco para o Git)
*.conf
odoo.conf
.odoorc

# Sessões locais e dumps de banco de dados para testes
*.sql
*.dump

# ------------------------------------------------------------------------------
# 3. ROS & ROS 2 (Robot Operating System)
# ------------------------------------------------------------------------------
# Diretórios de build e instalação locais do Catkin / Colcon
install/
log/
devel/
.catkin_workspace
.colcon/

# Arquivos de log e mensagens de diagnóstico do ROS
.ros/
*.bag

# ------------------------------------------------------------------------------
# 4. Sistemas Embarcados & IoT (ESP32, Raspberry Pi, UDOO x86)
# ------------------------------------------------------------------------------
# PlatformIO (Gerenciador recomendado para ESP32)
.pio/
.pioenvs/
.piolibdeps/
.clang_complete

# Arduino IDE (Arquivos temporários de compilação)
*.ino.elf
*.ino.hex
*.ino.with_bootloader.bin
*.ino.partitions.bin

# Arquivos de sistema específicos de SBCs (Ubuntu / Raspberry Pi OS)
.DS_Store
Thumbs.db
*~
*.swp
*.bak

# ------------------------------------------------------------------------------
# 5. Ambientes Virtuais e Variáveis de Ambiente (Segurança)
# ------------------------------------------------------------------------------
.env
.envrc
.venv
env/
venv/
ENV/

# ------------------------------------------------------------------------------
# 6. IDEs e Editores (VS Code, PyCharm/Clion)
# ------------------------------------------------------------------------------
# Comum em times de desenvolvimento: ignorar configurações locais de workspace
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
tempCodeRunnerFile*

# ------------------------------------------------------------------------------
# 7. Testes e Qualidade de Código
# ------------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
